<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="Customer Segmentation &amp; Revenue Strategy Analysis_SQLDatabase.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1287"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="Data" custom_title="0" dock_id="2" table="4,4:mainData"/><dock_state state="000000ff00000000fd0000000100000002000003db0000031efc0100000002fb000000160064006f0063006b00420072006f00770073006500310100000000000003db0000000000000000fb000000160064006f0063006b00420072006f00770073006500320100000000000003db0000013900ffffff000002580000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="Data" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="0" mode="1"/></sort><column_widths><column index="1" value="62"/><column index="2" value="280"/><column index="3" value="56"/><column index="4" value="132"/><column index="5" value="59"/><column index="6" value="56"/><column index="7" value="75"/><column index="8" value="117"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">
--Check the Dataset
SELECT *
FROM Data
LIMIT 10;

SELECT Order_Date
FROM Data
LIMIT 5;

--Extract Date Only
SELECT
    Order_Date,
    substr(Order_Date,1,10) AS OrderDate
FROM Data;

--Extract Time Only
SELECT
    Order_Date,
    substr(Order_Date,12,5) AS OrderTime
FROM Data;

--Extract Date &amp; Time Together
SELECT
    Order_ID,
    substr(Order_Date,1,10) AS OrderDate,
    substr(Order_Date,12,5) AS OrderTime
FROM Data;

--Convert to SQLite Standard Date Format
SELECT
    Order_ID,
    substr(Order_Date,7,4) || '-' ||
    substr(Order_Date,4,2) || '-' ||
    substr(Order_Date,1,2) AS formatted_date
FROM Data;

ALTER TABLE Data ADD COLUMN OrderDate TEXT;
ALTER TABLE Data ADD COLUMN OrderTime TEXT;

UPDATE Data
SET 
OrderDate = substr(Order_Date,1,10),
OrderTime = substr(Order_Date,12,5);

--Convert DD-MM-YYYY → YYYY-MM-DD
SELECT 
    substr(Order_Date,7,4) || '-' ||  -- year
    substr(Order_Date,4,2) || '-' ||  -- month
    substr(Order_Date,1,2) AS formatted_date
FROM Data;

--Basic Business KPIs
SELECT
    COUNT(DISTINCT CustomerID) AS total_customers,
    COUNT(DISTINCT Order_ID) AS total_orders,
    SUM(Revenue) AS total_revenue,
    AVG(Revenue) AS avg_order_value
FROM Data;

--Top Products by Revenue
SELECT
    Product,
    SUM(Quantity) AS units_sold,
    SUM(Revenue) AS product_revenue
FROM Data
GROUP BY Product
ORDER BY product_revenue DESC
LIMIT 10;

--Revenue by Country
SELECT
    Country,
    SUM(Revenue) AS revenue
FROM Data
GROUP BY Country
ORDER BY revenue DESC;

--Top Customers (High Value Customers)
SELECT
    CustomerID,
    COUNT(Order_ID) AS orders_count,
    SUM(Revenue) AS total_spent
FROM Data
GROUP BY CustomerID
ORDER BY total_spent DESC
LIMIT 10;

--Customer Segmentation
SELECT
    CustomerID,
    SUM(Revenue) AS total_spent,
    COUNT(Order_ID) AS total_orders,	
    CASE
        WHEN SUM(Revenue) &gt; 1000 THEN 'High Value'
        WHEN SUM(Revenue) BETWEEN 500 AND 1000 THEN 'Medium Value'
        ELSE 'Low Value'
    END AS customer_segment
FROM Data
GROUP BY CustomerID;

--Monthly Revenue Trend (SQLite Compatible)
SELECT
    strftime('%Y-%m', OrderDate) AS month,
    SUM(Revenue) AS monthly_revenue
FROM Data
GROUP BY month
ORDER BY month;

--Top Countries by Customer Count
SELECT
    Country,
    COUNT(DISTINCT CustomerID) AS total_customers
FROM Data
GROUP BY Country
ORDER BY total_customers DESC;

--. Most Frequently Purchased Products
SELECT
    Product,
    COUNT(Order_ID) AS purchase_frequency
FROM Data
GROUP BY Product
ORDER BY purchase_frequency DESC
LIMIT 10;

--Customer Purchase Frequency
SELECT
    CustomerID,
    COUNT(Order_ID) AS total_orders
FROM Data
GROUP BY CustomerID
ORDER BY total_orders DESC;</sql><current_tab id="0"/></tab_sql></sqlb_project>
